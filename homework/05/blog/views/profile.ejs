<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= profileUser.username %> - gogogo</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #000; color: #fff; min-height: 100vh; }
        a { color: inherit; text-decoration: none; }
        
        .header { padding: 15px 20px; border-bottom: 1px solid #2e2e2e; display: flex; align-items: center; gap: 20px; }
        .back-btn { font-size: 20px; cursor: pointer; padding: 8px; }
        .header h1 { font-size: 20px; }
        
        .profile-header { padding: 20px; border-bottom: 1px solid #2e2e2e; }
        .profile-avatar { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 40px; margin-bottom: 15px; }
        .profile-name { font-size: 22px; font-weight: 700; margin-bottom: 5px; }
        .profile-handle { color: #666; margin-bottom: 15px; }
        .profile-bio { font-size: 15px; line-height: 1.5; margin-bottom: 15px; }
        .profile-stats { display: flex; gap: 25px; color: #666; font-size: 14px; }
        .profile-stats strong { color: #fff; }
        .profile-actions { margin-top: 20px; display: flex; gap: 10px; }
        
        .follow-btn { background: #fff; color: #000; border: none; padding: 10px 25px; border-radius: 20px; font-weight: 600; cursor: pointer; }
        .follow-btn:hover { opacity: 0.9; }
        .edit-btn { background: #1a1a1a; color: #fff; border: 1px solid #333; padding: 10px 25px; border-radius: 20px; font-weight: 600; cursor: pointer; }
        
        .tabs { display: flex; border-bottom: 1px solid #2e2e2e; }
        .tab { flex: 1; padding: 15px; text-align: center; font-weight: 600; color: #888; cursor: pointer; }
        .tab:hover { background: #0a0a0a; }
        .tab.active { color: #fff; border-bottom: 2px solid #fff; }
        
        .posts { padding: 0; }
        .post { padding: 20px; border-bottom: 1px solid #2e2e2e; display: flex; gap: 15px; }
        .post:hover { background: #0a0a0a; }
        .post-content { flex: 1; }
        .post-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .post-header .name { font-weight: 600; }
        .post-header .time { color: #666; font-size: 14px; }
        .post-text { font-size: 15px; line-height: 1.5; white-space: pre-wrap; }
        .post-actions { display: flex; gap: 20px; margin-top: 12px; }
        .post-action { color: #666; cursor: pointer; font-size: 14px; border: none; background: none; }
        .post-action:hover { color: #fff; }
        .post-action.liked { color: #e91e63; }
        .private-badge { background: #333; padding: 2px 8px; border-radius: 10px; font-size: 10px; color: #888; margin-left: 5px; }
        
        .empty-state { text-align: center; padding: 60px 20px; color: #666; }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="back-btn">←</a>
        <h1><%= profileUser.username %></h1>
    </div>
    
    <div class="profile-header">
        <div class="profile-avatar"><%= profileUser.username[0].toUpperCase() %></div>
        <div class="profile-name"><%= profileUser.username %></div>
        <div class="profile-handle">@<%= profileUser.username %></div>
        <% if (profileUser.bio) { %>
            <div class="profile-bio"><%= profileUser.bio %></div>
        <% } %>
        <div class="profile-stats">
            <span><strong><%= profileUser.posts %></strong> posts</span>
            <span><strong><%= profileUser.followers %></strong> followers</span>
            <span><strong><%= profileUser.following %></strong> following</span>
        </div>
        <div class="profile-actions">
            <% if (user && user.id === profileUser.id) { %>
                <button class="edit-btn" onclick="alert('Edit profile coming soon!')">Edit profile</button>
            <% } else if (user) { %>
                <% if (isFollowingUser) { %>
                    <form action="/unfollow" method="POST">
                        <input type="hidden" name="user_id" value="<%= profileUser.id %>">
                        <button type="submit" class="edit-btn">Following</button>
                    </form>
                <% } else { %>
                    <form action="/follow" method="POST">
                        <input type="hidden" name="user_id" value="<%= profileUser.id %>">
                        <button type="submit" class="follow-btn">Follow</button>
                    </form>
                <% } %>
            <% } %>
        </div>
    </div>
    
    <div class="tabs">
        <div class="tab active">Posts</div>
        <div class="tab">Replies</div>
        <div class="tab">Likes</div>
    </div>
    
    <div class="posts">
        <% if (posts.length === 0) { %>
            <div class="empty-state">
                <p>No posts yet</p>
            </div>
        <% } %>
        <% posts.forEach(post => { %>
            <div class="post">
                <div class="avatar" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 16px;">
                    <%= profileUser.username[0].toUpperCase() %>
                </div>
                <div class="post-content">
                    <div class="post-header">
                        <span class="name"><%= profileUser.username %></span>
                        <span class="time"><%= post.created_at %></span>
                        <% if (!post.is_public) { %>
                            <span class="private-badge">🔒 Private</span>
                        <% } %>
                    </div>
                    <div class="post-text"><%= post.content %></div>
                    <div class="post-actions">
                        <% if (user) { %>
                            <% if (post.isLiked) { %>
                                <form action="/unlike" method="POST" style="display: inline;">
                                    <input type="hidden" name="post_id" value="<%= post.id %>">
                                    <button type="submit" class="post-action liked">❤️ <%= post.likes %></button>
                                </form>
                            <% } else { %>
                                <form action="/like" method="POST" style="display: inline;">
                                    <input type="hidden" name="post_id" value="<%= post.id %>">
                                    <button type="submit" class="post-action">🤍 <%= post.likes %></button>
                                </form>
                            <% } %>
                        <% } else { %>
                            <span class="post-action">❤️ <%= post.likes %></span>
                        <% } %>
                        <a href="/post/<%= post.id %>" class="post-action">💬 <%= post.commentsCount %></a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>
