<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thread</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #000; color: #fff; min-height: 100vh; }
        a { color: inherit; text-decoration: none; }
        
        .header { padding: 15px 20px; border-bottom: 1px solid #2e2e2e; display: flex; align-items: center; gap: 20px; }
        .back-btn { font-size: 20px; cursor: pointer; padding: 8px; }
        .header h1 { font-size: 20px; }
        
        .thread { padding: 20px; }
        .post-main { display: flex; gap: 15px; }
        .post-main .avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 18px; flex-shrink: 0; }
        .post-content { flex: 1; }
        .post-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
        .post-header .name { font-weight: 600; }
        .post-header .time { color: #666; font-size: 14px; }
        .post-text { font-size: 18px; line-height: 1.5; white-space: pre-wrap; margin-bottom: 20px; }
        .post-date { color: #666; font-size: 14px; padding-bottom: 20px; border-bottom: 1px solid #2e2e2e; margin-bottom: 20px; }
        
        .reply-box { display: flex; gap: 15px; padding: 20px; border-top: 1px solid #2e2e2e; }
        .reply-box textarea { flex: 1; background: #1a1a1a; border: 1px solid #333; border-radius: 20px; padding: 12px 20px; color: #fff; font-size: 14px; resize: none; outline: none; min-height: 50px; }
        .reply-box button { background: #fff; color: #000; border: none; padding: 8px 20px; border-radius: 20px; font-weight: 600; cursor: pointer; align-self: flex-start; }
        
        .actions { display: flex; gap: 30px; padding: 15px 0; border-bottom: 1px solid #2e2e2e; }
        .action { color: #666; cursor: pointer; display: flex; align-items: center; gap: 8px; }
        .action:hover { color: #fff; }
        .action.liked { color: #e91e63; }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="back-btn">←</a>
        <h1>Thread</h1>
    </div>
    
    <div class="thread">
        <div class="post-main">
            <div class="avatar"><%= post.username[0].toUpperCase() %></div>
            <div class="post-content">
                <div class="post-header">
                    <a href="/profile/<%= post.user_id %>"><span class="name"><%= post.username %></span></a>
                    <span class="time">@<%= post.username %></span>
                    <span class="time">· <%= post.created_at %></span>
                </div>
                <div class="post-text"><%= post.content %></div>
                <div class="post-date"><%= post.created_at %></div>
                <div class="actions">
                    <span class="action">❤️ 0 likes</span>
                    <span class="action">💬 0 replies</span>
                    <span class="action">🔄 Repost</span>
                    <span class="action">📤 Share</span>
                </div>
            </div>
        </div>
        
        <% if (user) { %>
            <div class="reply-box">
                <div class="avatar" style="width: 35px; height: 35px; font-size: 14px;"><%= user.username[0].toUpperCase() %></div>
                <textarea placeholder="Post your reply..."></textarea>
                <button>Reply</button>
            </div>
        <% } else { %>
            <div style="padding: 20px; text-align: center; color: #666; border-top: 1px solid #2e2e2e;">
                <a href="/login" style="color: #833ab4;">Login</a> to reply
            </div>
        <% } %>
    </div>
</body>
</html>
