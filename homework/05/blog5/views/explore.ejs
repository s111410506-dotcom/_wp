<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explore - Threads</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #000; color: #fff; min-height: 100vh; }
        a { color: inherit; text-decoration: none; }
        
        .header { padding: 15px 20px; border-bottom: 1px solid #2e2e2e; display: flex; align-items: center; gap: 20px; }
        .back-btn { font-size: 20px; cursor: pointer; padding: 8px; }
        .search-box { flex: 1; max-width: 400px; background: #1a1a1a; border: none; border-radius: 20px; padding: 10px 20px; color: #fff; font-size: 14px; outline: none; }
        
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        h2 { margin-bottom: 20px; font-size: 20px; }
        
        .users-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; margin-bottom: 40px; }
        .user-card { background: #0a0a0a; border: 1px solid #2e2e2e; border-radius: 15px; padding: 20px; text-align: center; }
        .user-card:hover { background: #111; }
        .avatar { width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(45deg, #833ab4, #fd1d1d, #fcb045); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 28px; margin: 0 auto 15px; }
        .user-card .name { font-weight: 600; margin-bottom: 5px; }
        .user-card .bio { color: #666; font-size: 13px; margin-bottom: 15px; }
        .follow-btn { background: #fff; color: #000; border: none; padding: 8px 24px; border-radius: 20px; font-weight: 600; cursor: pointer; }
        
        .posts-section { margin-top: 40px; }
        .post { padding: 20px; border-bottom: 1px solid #2e2e2e; display: flex; gap: 15px; }
        .post:hover { background: #0a0a0a; }
        .post-content { flex: 1; }
        .post-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .post-header .name { font-weight: 600; }
        .post-header .time { color: #666; font-size: 14px; }
        .post-text { font-size: 15px; line-height: 1.5; white-space: pre-wrap; }
        .post-actions { display: flex; gap: 20px; margin-top: 12px; }
        .post-action { color: #666; cursor: pointer; font-size: 14px; }
        .post-action:hover { color: #fff; }
        
        .empty-state { text-align: center; padding: 40px; color: #666; }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="back-btn">←</a>
        <h1 style="font-size: 20px;">Explore</h1>
        <input type="text" class="search-box" placeholder="Search users...">
    </div>
    
    <div class="container">
        <div class="users-section">
            <h2>Suggested Users</h2>
            <div class="users-grid">
                <% users.forEach(u => { %>
                    <% if (!user || u.id !== user.id) { %>
                        <div class="user-card">
                            <a href="/profile/<%= u.id %>">
                                <div class="avatar"><%= u.username[0].toUpperCase() %></div>
                                <div class="name"><%= u.username %></div>
                                <div class="bio"><%= u.bio || 'No bio yet' %></div>
                            </a>
                            <% if (user) { %>
                                <form action="/follow" method="POST">
                                    <input type="hidden" name="user_id" value="<%= u.id %>">
                                    <button type="submit" class="follow-btn">Follow</button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>
                <% }) %>
            </div>
        </div>
        
        <div class="posts-section">
            <h2>Recent Posts</h2>
            <% if (publicPosts.length === 0) { %>
                <div class="empty-state">No posts yet</div>
            <% } %>
            <% publicPosts.forEach(post => { %>
                <div class="post">
                    <a href="/profile/<%= post.user_id %>">
                        <div class="avatar" style="width: 40px; height: 40px; font-size: 16px; flex-shrink: 0;">-<%= post.username[0].toUpperCase() %></div>
                    </a>
                    <div class="post-content">
                        <div class="post-header">
                            <a href="/profile/<%= post.user_id %>"><span class="name"><%= post.username %></span></a>
                            <span class="time"><%= post.created_at %></span>
                        </div>
                        <div class="post-text"><%= post.content %></div>
                        <div class="post-actions">
                            <span class="post-action">❤️ 0</span>
                            <a href="/post/<%= post.id %>" class="post-action">💬 Reply</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
