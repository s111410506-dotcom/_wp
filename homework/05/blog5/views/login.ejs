<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Threads</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #000; color: #fff; min-height: 100vh; display: flex; justify-content: center; align-items: center; }
        
        .container { width: 100%; max-width: 400px; padding: 20px; }
        .logo { text-align: center; font-size: 48px; font-weight: 700; margin-bottom: 30px; }
        h1 { text-align: center; margin-bottom: 10px; font-size: 24px; }
        p { text-align: center; color: #666; margin-bottom: 30px; }
        
        .form { background: #0a0a0a; border: 1px solid #2e2e2e; border-radius: 15px; padding: 30px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-size: 14px; color: #888; }
        input { width: 100%; padding: 14px; background: #1a1a1a; border: 1px solid #333; border-radius: 10px; color: #fff; font-size: 15px; outline: none; transition: border-color 0.2s; }
        input:focus { border-color: #833ab4; }
        input::placeholder { color: #555; }
        
        .btn { width: 100%; padding: 14px; background: #fff; color: #000; border: none; border-radius: 25px; font-size: 15px; font-weight: 600; cursor: pointer; }
        .btn:hover { opacity: 0.9; }
        
        .error { background: rgba(220, 53, 69, 0.2); border: 1px solid #dc3545; color: #f8d7da; padding: 12px; border-radius: 10px; margin-bottom: 20px; font-size: 14px; text-align: center; }
        
        .divider { text-align: center; margin: 25px 0; color: #666; position: relative; }
        .divider::before, .divider::after { content: ''; position: absolute; top: 50%; width: 40%; height: 1px; background: #2e2e2e; }
        .divider::before { left: 0; }
        .divider::after { right: 0; }
        
        .social-btn { width: 100%; padding: 12px; background: #1a1a1a; border: 1px solid #333; border-radius: 25px; color: #fff; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 15px; }
        .social-btn:hover { background: #222; }
        
        .link { text-align: center; margin-top: 25px; color: #666; font-size: 14px; }
        .link a { color: #fff; font-weight: 600; }
        .link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">𝕏</div>
        <h1>Welcome back</h1>
        <p>Sign in to your account</p>
        
        <div class="form">
            <% if (error) { %>
                <div class="error"><%= error %></div>
            <% } %>
            
            <form action="/login" method="POST">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" required placeholder="Enter your username">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" required placeholder="Enter your password">
                </div>
                <button type="submit" class="btn">Sign in</button>
            </form>
            
            <div class="divider">or</div>
            
            <button class="social-btn">🔵 Continue with Google</button>
            
            <div class="link">
                Don't have an account? <a href="/register">Sign up</a>
            </div>
        </div>
    </div>
</body>
</html>
